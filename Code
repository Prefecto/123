$ProcessName = "svchost"
$HandleLimit = 15000

while ($true) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    
    # Первая выборка: все процессы с превышением лимита
    $firstSnapshot = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue | Where-Object { $_.HandleCount -gt $HandleLimit }
    
    if ($firstSnapshot) {
        # Запоминаем ID подозрительных процессов
        $firstIDs = $firstSnapshot | Select-Object -ExpandProperty Id
        $firstInfo = $firstSnapshot | ForEach-Object { "PID=$($_.Id) Handles=$($_.HandleCount)" }
        Write-Host "$timestamp — НАЙДЕНЫ: $($firstInfo -join ', ')" -ForegroundColor Yellow
        
        # Ждем 10 секунд
        Start-Sleep -Seconds 10
        
        # Вторая выборка: снова ищем процессы с превышением
        $secondSnapshot = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue | Where-Object { $_.HandleCount -gt $HandleLimit }
        $secondIDs = $secondSnapshot | Select-Object -ExpandProperty Id
        
        # Ищем пересечения (процессы, которые были в обоих выборках)
        $toKill = $firstIDs | Where-Object { $_ -in $secondIDs }
        
        if ($toKill) {
            foreach ($id in $toKill) {
                try {
                    $proc = Get-Process -Id $id -ErrorAction SilentlyContinue
                    if ($proc) {
                        $killTimestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
                        Write-Host "$killTimestamp — УБИВАЮ (висел 10+ сек): PID=$($proc.Id) Handles=$($proc.HandleCount)" -ForegroundColor Red
                        Stop-Process -Id $proc.Id -Force
                        Start-Sleep -Milliseconds 500
                    }
                }
                catch {
                    $killTimestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
                    Write-Host "$killTimestamp — ОШИБКА при убийстве PID=$id : $_" -ForegroundColor Magenta
                }
            }
        }
        else {
            Write-Host "$timestamp — Процессы сбросили хэндлы за 10 сек, убийство отменено" -ForegroundColor Green
        }
    }
    
    Start-Sleep -Seconds 3
}
